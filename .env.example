# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://postgres:password@host:5432/zippygo
DIRECT_URL=postgresql://postgres:password@host:5432/zippygo

# Cloudflare R2
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=zippygo-media
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Firebase Cloud Messaging (Future)
NEXT_PUBLIC_FCM_API_KEY=your-fcm-api-key
NEXT_PUBLIC_FCM_PROJECT_ID=your-fcm-project-id
NEXT_PUBLIC_FCM_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FCM_APP_ID=your-fcm-app-id
FCM_SERVER_KEY=your-fcm-server-key

# Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zippy Go
NEXT_PUBLIC_APP_TAGLINE=One Food Court. One Cart. One Checkout.

# Rate Limiting
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# SMTP (Future)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASS=your-password
SMTP_FROM=noreply@zippygo.com

# Google OAuth (Future)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# GitHub OAuth (Future)
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
